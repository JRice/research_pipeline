# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by both the API and the worker.
DATABASE_URL=postgresql://pipeline:pipeline@postgres:5432/sensor_pipeline

# ── Worker ────────────────────────────────────────────────────────────────────
# Default path to the CSV that ingest.py loads.
INPUT_CSV=/data/sample_data.csv
# ECS/Fargate worker runs can instead point at an S3 object.
# INPUT_S3_URI=s3://your-bucket/sample_data.csv

# ── API (POST /ingest convenience endpoint) ───────────────────────────────────
# Path to compose.yml as seen from *inside* the API container.
# The file is mounted read-only via compose.yml's api.volumes section.
COMPOSE_FILE=/app/compose.yml

# ── AWS (Terraform / GitHub Actions) ─────────────────────────────────────────
AWS_REGION=us-east-1
# IAM role ARN that GitHub Actions assumes via OIDC.
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/github-actions-deploy

# ECS names must match the values in terraform/variables.tf
ECS_CLUSTER=research-pipeline
ECS_APP_SERVICE=research-pipeline-app  # combined nginx+api task
